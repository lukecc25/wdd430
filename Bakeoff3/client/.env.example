# Firebase web app only (client-side). No Clerk. No admin private key here.
# Admin credentials belong in server/.env only.
# Project: cookquest-3b152 — Project settings → Your apps → Web app

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=cookquest-3b152.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=cookquest-3b152
VITE_FIREBASE_STORAGE_BUCKET=cookquest-3b152.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=687542104139
VITE_FIREBASE_APP_ID=1:687542104139:web:your-app-id

# GraphQL API (local dev uses Vite proxy; production = your deployed server URL)
VITE_GRAPHQL_URL=http://localhost:4000/graphql
